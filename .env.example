# Copy this file to .env and fill in your values
# Never commit .env to source control

# Azure OpenAI — Embedding (East US 2)
AZURE_OPENAI_ENDPOINT=https://<your-embedding-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-embedding-api-key>
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Azure OpenAI — Chat (Sweden Central) Had separate resource for chat to demonstrate cross-resource capabilities and also for scenarios where resouces are not available, but you can use the same resource for both if you prefer
AZURE_CHAT_ENDPOINT=https://<your-chat-resource>.openai.azure.com/
AZURE_CHAT_API_KEY=<your-chat-api-key>
AZURE_CHAT_DEPLOYMENT=gpt-4o

# Azure AI Search (Production vector store)
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_API_KEY=<your-search-api-key>
AZURE_SEARCH_INDEX=rag-chunks

# Vector store: 'local' uses FAISS (in-memory), 'azure' uses Azure AI Search
VECTOR_STORE=azure